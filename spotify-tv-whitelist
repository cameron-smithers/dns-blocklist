! Title: Roku Spotify Whitelist
! Description: Allows Spotify to work on Roku while keeping Roku ads, telemetry, Netflix, and other services blocked.
! Syntax: AdGuard Home DNS filtering rules

! =========================
! Roku: allow Spotify only
! =========================

@@||spotify.com^$client=Roku,important
@@||spoti.fi^$client=Roku,important
@@||scdn.co^$client=Roku,important
@@||spotifycdn.com^$client=Roku,important
@@||spotifycdn.net^$client=Roku,important

! Spotify app/API endpoints
@@||spclient.wg.spotify.com^$client=Roku,important
@@||apresolve.spotify.com^$client=Roku,important
@@||dealer.spotify.com^$client=Roku,important
@@||api-tv.spotify.com^$client=Roku,important
@@||gew-spclient.spotify.com^$client=Roku,important
@@||gae2-spclient.spotify.com^$client=Roku,important

! =========================
! Roku: allow only the platform services needed to launch channels
! =========================

@@||api.roku.com^$client=Roku,important
@@||api2.sr.roku.com^$client=Roku,important
@@||images.sr.roku.com^$client=Roku,important
@@||channels.roku.com^$client=Roku,important
@@||rsp.web.roku.com^$client=Roku,important
@@||cloudservices.roku.com^$client=Roku,important

